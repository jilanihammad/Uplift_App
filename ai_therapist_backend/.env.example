# ===== AI THERAPIST BACKEND CONFIGURATION TEMPLATE =====
# Copy this file to .env and fill in your actual values
# NEVER commit the actual .env file with real secrets!

# ===== DATABASE CONFIGURATION =====
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_database_password_here
POSTGRES_DB=ai_therapist

# ===== SECURITY CONFIGURATION =====
SECRET_KEY=your_secret_key_here_generate_a_strong_one
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ENCRYPTION_KEY=your_encryption_key_here

# ===== API CONFIGURATION =====
API_V1_STR=/api/v1
SERVER_HOST=http://localhost:8000

# For production deployment:
# SERVER_HOST=https://your-backend-url.com

# ===== LLM API KEYS =====
# Groq Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_LLM_MODEL_ID=llama-3.3-70b-versatile

# Google Configuration  
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_LLM_MODEL_ID=gemini-2.5-flash
GOOGLE_TTS_MODEL=gemini-2.5-flash-preview-tts
GOOGLE_TRANSCRIPTION_MODEL=gemini-2.5-flash-lite-preview-06-17
GOOGLE_TTS_VOICE=Zephyr
GOOGLE_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=sage
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe

# Hugging Face (if needed)
# HUGGINGFACE_TOKEN=your_huggingface_token_here

# ===== PAYMENT CONFIGURATION =====
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
BASIC_MONTHLY_PRICE_ID=price_basic_monthly
BASIC_YEARLY_PRICE_ID=price_basic_yearly
PREMIUM_MONTHLY_PRICE_ID=price_premium_monthly
PREMIUM_YEARLY_PRICE_ID=price_premium_yearly

# ===== FEATURE FLAGS =====
LLM_STREAMING_ENABLED=false

# ===== TTS CONFIGURATION =====
# Google TTS Configuration (Half-Cascade Models for Production)
GOOGLE_TTS_MODEL=gemini-live-2.5-flash-preview
# Alternative: GOOGLE_TTS_MODEL=gemini-2.0-flash-live-001
GOOGLE_TTS_VOICE=zephyr

# ===== SETUP INSTRUCTIONS =====
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys and secrets
# 3. Never commit the .env file to version control!
# 4. For team setup, share this template file instead of actual credentials