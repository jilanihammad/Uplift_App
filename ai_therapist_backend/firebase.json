{
  "functions": {
    "source": ".",
    "runtime": "python310",
    "ignore": [
      ".venv/**",
      ".git/**",
      "venv/**",
      ".pytest_cache/**",
      "**/node_modules/**",
      "**/__pycache__/**"
    ]
  },
  "hosting": {
    "public": "static",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "function": "api"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}