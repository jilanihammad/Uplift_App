FROM python:3.11-slim

WORKDIR /app

# Copy requirements first for better caching
COPY requirements.txt .

# Force clean installation of OpenAI SDK to ensure we get the correct version
# This prevents any cached wheels from older versions persisting
RUN pip uninstall -y openai && \
    pip install --no-cache-dir openai==1.95.0 && \
    pip install --no-cache-dir -r requirements.txt

# Copy all application code
COPY . .

# Port on which the application will run
ENV PORT=8080

# Expose the port
EXPOSE 8080

# Increase keepalive timeout
ENV UVICORN_TIMEOUT=300

# Copy entrypoint script
COPY scripts/entrypoint.sh /app/entrypoint.sh
RUN chmod +x /app/entrypoint.sh

# Start the application with migrations via entrypoint script
CMD ["/app/entrypoint.sh"] 
